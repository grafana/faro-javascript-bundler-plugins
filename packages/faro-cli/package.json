{
  "name": "@grafana/faro-cli",
  "version": "0.10.0",
  "description": "CLI for uploading sourcemaps to the Faro source map API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./dist/cli.js": "./dist/cli.js"
  },
  "bin": "dist/cli.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/faro-javascript-bundler-plugins",
    "directory": "packages/faro-cli"
  },
  "license": "Apache-2.0",
  "author": "Grafana Labs",
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@grafana/faro-bundlers-shared": "^0.11.0",
    "commander": "^14.0.0",
    "dotenv": "^17.0.1",
    "glob": "^13.0.0",
    "tar": "^7.1.0"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@rollup/plugin-typescript": "11.1.6",
    "@types/glob": "9.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.4",
    "@types/tar": "7.0.87",
    "jest": "30.4.2",
    "ts-jest": "29.4.11"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
