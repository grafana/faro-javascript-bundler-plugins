{
  "name": "@grafana/faro-esbuild-plugin",
  "version": "0.6.0",
  "description": "Upload a source map to the Faro source map API from an esbuild build pipeline",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/faro-javascript-bundler-plugins",
    "directory": "packages/faro-esbuild"
  },
  "license": "Apache-2.0",
  "author": "Grafana Labs",
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "test": "jest"
  },
  "dependencies": {
    "@grafana/faro-bundlers-shared": "^0.11.0",
    "esbuild": "^0.28.0"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@types/jest": "30.0.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.11"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
